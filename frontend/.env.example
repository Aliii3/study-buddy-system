# --- Client: point at microservices, or omit to use built-in /api/graphql/* on same origin ---
NEXT_PUBLIC_USER_API=http://localhost:4001/graphql
NEXT_PUBLIC_AVAILABILITY_API=http://localhost:4000/graphql
NEXT_PUBLIC_SESSION_API=http://localhost:4002/graphql
NEXT_PUBLIC_NOTIFICATION_API=http://localhost:4003/graphql
NEXT_PUBLIC_MATCHING_API=http://localhost:4004/graphql
NEXT_PUBLIC_PROFILE_API=http://localhost:4005/graphql

# --- Server only (Next.js API route): Postgres persists demo GraphQL state in table study_buddy_state ---
# Copy to .env.local. Use Neon pooled URL with sslmode=require (see Neon dashboard).
# DATABASE_URL=postgresql://USER:PASSWORD@HOST/DB?sslmode=require&channel_binding=require
# AUTH_SECRET=long-random-string-for-login-tokens
